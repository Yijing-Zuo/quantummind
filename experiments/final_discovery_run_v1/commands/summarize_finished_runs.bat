@echo off
REM Summarize finished final discovery runs. No API keys are stored in this file.
powershell -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference = 'Stop'; $manifest = 'experiments\final_discovery_run_v1\manifests\master_run_manifest.csv'; $logs = 'experiments\final_discovery_run_v1\logs'; $rows = @(Import-Csv -LiteralPath $manifest); $summary = foreach ($r in $rows) { $stdout = Join-Path $logs ($r.global_task_id + '.stdout.log'); $stderr = Join-Path $logs ($r.global_task_id + '.stderr.log'); [pscustomobject]@{ global_task_id=$r.global_task_id; subset=$r.subset; kind=$r.kind; card_id=$r.card_id; shard_id=$r.shard_id; stdout_log_present=(Test-Path -LiteralPath $stdout); stderr_log_present=(Test-Path -LiteralPath $stderr); output_dir=$r.output_dir; run_dir_count=@(Get-ChildItem -Directory -Path $r.output_dir -ErrorAction SilentlyContinue).Count } }; $summary | Export-Csv -NoTypeInformation -Path 'experiments\final_discovery_run_v1\reports\final_finished_run_summary.csv'; '# Final Finished Run Summary' | Set-Content -Path 'experiments\final_discovery_run_v1\reports\final_finished_run_summary.md'; ('Rows summarized: ' + $summary.Count) | Add-Content -Path 'experiments\final_discovery_run_v1\reports\final_finished_run_summary.md'; Write-Host ('Wrote {0}' -f 'experiments\final_discovery_run_v1\reports\final_finished_run_summary.csv')"
